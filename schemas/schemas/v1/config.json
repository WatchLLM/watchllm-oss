{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WatchLLM Config",
  "description": "Configuration schema for WatchLLM projects (.watchllm.yaml)",
  "type": "object",
  "properties": {
    "rules": {
      "type": "object",
      "properties": {
        "boundary": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "severity": { "type": "string", "enum": ["error", "warning"], "default": "error" },
            "map": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "forbidden": {
                    "type": "array",
                    "items": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 2,
                      "maxItems": 2
                    }
                  },
                  "allowed": {
                    "type": "array",
                    "items": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 2,
                      "maxItems": 2
                    }
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "forbidden_imports": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "severity": { "type": "string", "enum": ["error", "warning"], "default": "error" },
            "modules": {
              "type": "array",
              "items": { "type": "string" }
            },
            "forbidden_prefixes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowed_relative_prefixes": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "secrets": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "severity": { "type": "string", "enum": ["error", "warning"], "default": "error" }
          },
          "additionalProperties": false
        },
        "auth_flow": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "severity": { "type": "string", "enum": ["error", "warning"], "default": "error" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
